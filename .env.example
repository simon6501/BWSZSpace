# 本地默认端口
PORT=3077
HOST=127.0.0.1

# 第一次启动时用于初始化管理员账号；创建 data/users.json 后再修改这里不会自动覆盖账号
APP_USERNAME=bwsz
APP_PASSWORD=please-change-this-local-password
APP_DISPLAY_NAME=BW & SZ

# 部署到公网前请换成随机长字符串
SESSION_SECRET=replace-with-a-long-random-secret-before-public-deploy

# 当前本地开发默认关闭登录；需要恢复密码登录时改成 false
LOGIN_DISABLED=true
