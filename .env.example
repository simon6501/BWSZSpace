# Local development server
PORT=3077
HOST=127.0.0.1

# Local development may disable login. Never use this for public/tunnel access.
LOGIN_DISABLED=true

# Public/tunnel local-server mode must use LOGIN_DISABLED=false and strong passwords.
BW_PASSWORD=change-this-bw-password
SZ_PASSWORD=change-this-sz-password

# Replace with a long random string before exposing the Node server.
SESSION_SECRET=replace-with-a-long-random-secret-before-public-deploy
