# Current-computer server mode
PORT=3077

# Keep 127.0.0.1 when using Cloudflare Tunnel or Caddy on the same computer.
# Use 0.0.0.0 only if you want other devices on the same LAN to access it directly.
HOST=127.0.0.1

# Public access must enable login.
LOGIN_DISABLED=false
APP_DISPLAY_NAME=BW & SZ

# Initial passwords are only used before data/users.json exists.
# If users.json already exists, use:
#   node scripts/set_password.js "your-bw-password" bw
#   node scripts/set_password.js "your-sz-password" sz
BW_PASSWORD=change-this-bw-password
SZ_PASSWORD=change-this-sz-password

# Replace with a long random string before exposing to public network.
SESSION_SECRET=change-this-to-a-long-random-secret-at-least-32-chars
